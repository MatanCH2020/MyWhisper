  "release_on_fullscreen": true,
  "sounds": true,
  "sound_volume": 0.25,
  "initial_prompt": "שלום, מה שלומך? היום יום יפה.",
  "glossary_prompt": true,
  "llm_polish": false,
  "llm_model": "",
  "llm_url": "http://localhost:11434",
