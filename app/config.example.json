{
  "hotkey": "ctrl+space",
  "model": "ivrit-ai/whisper-large-v3-turbo-ct2",
  "language": "he",
  "device": "cuda",
  "compute_type": "float16",
  "beam_size": 5,
  "beam_size_cpu": 1,
  "cpu_threads": 0,
  "vad_filter": true,
  "input_device": "",
